# LLM service settings
ANTHROPIC_API_KEY=your_llm_api_key
ANTHROPIC_BASE_URL=https://your-llm-endpoint.example.com
ANTHROPIC_MODEL=your_model_name

# 飞书推送（可选）
FEISHU_CHAT_ID=oc_xxxxx
# 飞书消息里的 HTML 报告链接前缀。本机飞书可用 localhost；手机/他人访问需换成可访问的域名或内网地址。
PUBLIC_BASE_URL=http://localhost:3000

# Chrome CDP 远程调试（可选，连接真实浏览器）
# macOS 启动方式: /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome --remote-debugging-port=9222
# Windows 启动方式: "C:\Program Files\Google\Chrome\Application\chrome.exe" --remote-debugging-port=9222
# Windows 如自动检测失败，可设置: CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_PATH=
CDP_ENDPOINT=http://localhost:9222
